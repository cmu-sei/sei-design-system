{
  "compilerOptions": {
    "rootDir": ".",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "types": ["vite/client", "web-bluetooth", "unplugin-vue-router/client"]
  },
  "include": ["*.d.ts", "src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.stories.ts",
    "src/**/*.spec.js",
    "src/**/*.stories.js",
    "node_modules/*"
  ]
}
