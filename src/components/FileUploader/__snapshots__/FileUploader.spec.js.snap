exports[`FileUploader > should match its default snapshot 1`] = `<div data-id="sds-file-uploader" class="bg-white dark:bg-black border border-dashed border-gray-200 dark:border-gray-700 rounded-lg p-3"><div class="group relative"><input id="unique-id" type="file" name="sdsFileUploader" class="absolute inset-0 opacity-0 cursor-pointer"><div class="flex flex-col items-center space-y-1 rounded p-4 bg-gray-25 dark:bg-gray-900 group-hover:bg-gray-50 dark:group-hover:bg-gray-800"><label class="action-btn action-btn-ghost action-btn-blue action-btn-sm cursor-pointer font-semibold z-10"><svg width="11" height="13" viewBox="0 0 11 13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="my-auto" preserveAspectRatio="xMidYMid meet" role="img"><path d="M9.5 8.75C9.5 8.35156 9.82812 8 10.25 8C10.6484 8 11 8.35156 11 8.75V10.25C11 11.5156 9.99219 12.5 8.75 12.5H2.75C1.48438 12.5 0.5 11.5156 0.5 10.25V8.75C0.5 8.35156 0.828125 8 1.25 8C1.64844 8 2 8.35156 2 8.75V10.25C2 10.6719 2.32812 11 2.75 11H8.75C9.14844 11 9.5 10.6719 9.5 10.25V8.75ZM5.21094 0.734375C5.49219 0.429688 5.98438 0.429688 6.26562 0.734375L9.26562 3.73438C9.57031 4.01562 9.57031 4.50781 9.26562 4.78906C8.98438 5.09375 8.49219 5.09375 8.21094 4.78906L6.5 3.07812V8C6.5 8.42188 6.14844 8.75 5.75 8.75C5.32812 8.75 5 8.42188 5 8V3.07812L3.26562 4.78906C2.98438 5.09375 2.49219 5.09375 2.21094 4.78906C1.90625 4.50781 1.90625 4.01562 2.21094 3.73438L5.21094 0.734375Z" fill="currentColor"></path></svg>Upload file</label><p class="text-xs text-center font-semibold text-gray-900 dark:text-white leading-4">Click to upload or drag and drop a file here</p><p class="text-xs text-center text-gray-600 dark:text-gray-400 leading-4">Accepts .pdf, .json, .jpg, .jpeg, .png, .doc, .docx, .xls, .xlsx or .csv files under 10 MB.</p></div></div><!-- @slot File list content. @binding files, invalidFiles, removeFile, removeInvalidFile, byteToSize --><!--v-if--></div>`;
