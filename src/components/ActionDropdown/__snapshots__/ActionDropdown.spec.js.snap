// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ActionDropdown > should be block styling 1`] = `<div class="inline-block w-full" data-id="sds-action-dropdown"><div class="inline-block w-full"><!-- @slot Trigger content (used to replace trigger button). @binding open, close, isOpen, toggle --><button id="unique-id" type="button" class="space-x action-btn action-btn-secondary action-btn-red action-btn-md action-btn-block" aria-haspopup="true" aria-expanded="false"><!-- @slot Title content of trigger button. --><svg class="inline-block self-center w-5 h-5 -mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></button></div><!----></div>`;

