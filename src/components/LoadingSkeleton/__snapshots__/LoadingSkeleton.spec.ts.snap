exports[`LoadingSkeleton > matches snapshot with width and height prop assigned 1`] = `"<span data-id="sds-loading-skeleton" class="rounded-theme-sm flex flex-row relative overflow-hidden bg-gray-100 dark:bg-gray-800 animate-pulse w-1/2 h-32"></span>"`;

