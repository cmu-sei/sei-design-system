{
  "name": "@sds/components-vue3",
  "version": "3.8.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "serve": "vite preview",
    "lint": "NODE_OPTIONS='--trace-warnings' eslint .",
    "test": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest run -c vite-library.config.js",
    "test:watch": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest -c vite-library.config.js",
    "test:clean": "vitest run -u",
    "coverage": "vitest run --coverage",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "release-beta": "echo 'prerelease' | ./scripts/release-beta.sh",
    "release-next": "echo 'prerelease' | ./scripts/release-next.sh",
    "create-component": "./scripts/create-component.sh",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "gen-volar-dts": "./scripts/gen-component-declarations.sh"
  },
  "files": [
    "storybook-static",
    "dist",
    "src",
    "volar.d.ts"
  ],
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/src/components/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./volar": "./volar.d.ts"
  },
  "types": "./dist/types/src/components/index.d.ts",
  "main": "./dist/index.umd.js",
  "bugs": {
    "url": "https://issues.sei.cmu.edu/jira/projects/SDS"
  },
  "homepage": "https://designsystem.sei.cmu.edu/",
  "repository": {
    "type": "git",
    "url": "https://code.sei.cmu.edu/bitbucket/projects/SDS/repos/components-vue3/"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.1",
    "@eslint/js": "^9.11.1",
    "@floating-ui/dom": "^1.6.11",
    "@sds/tailwindcss-3": "^3.0.8-beta.8",
    "@shimyshack/uid": "^0.1.9",
    "@storybook/addon-actions": "^8.0.0",
    "@storybook/addon-docs": "^8.0.0",
    "@storybook/addon-essentials": "^8.3.6",
    "@storybook/addon-links": "^8.3.6",
    "@storybook/addon-storysource": "^8.3.6",
    "@storybook/vue3": "^8.0.0",
    "@storybook/vue3-vite": "^8.3.6",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@unhead/vue": "^1.11.10",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^11.1.0",
    "autoprefixer": "^10.4.20",
    "date-fns": "^4.1.0",
    "esbuild": "^0.24.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^9.30.0",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "mitt": "^3.0.1",
    "postcss": "^8.4.47",
    "storybook": "^8.3.6",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "unplugin-vue-router": "^0.10.8",
    "vite": "^5.4.10",
    "vitest": "^2.1.2",
    "vue": "^3.0.0",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.4.5",
    "vue-tsc": "^2.1.8"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
