{
  "name": "@sds/components-vue3",
  "version": "3.0.0-next.98",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore . --ignore-path .eslintignore .",
    "test": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest run -c vite-library.config.js",
    "test:watch": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest -c vite-library.config.js",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "release-beta": "echo 'prerelease' | ./scripts/release-beta.sh",
    "release-next": "echo 'prerelease' | ./scripts/release-next.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "gen-volar-dts": "./scripts/gen-component-declarations.sh"
  },
  "files": [
    "storybook-static",
    "dist",
    "src",
    "volar.d.ts"
  ],
  "sideEffects": false,
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "type": "module",
  "types": "./dist/types/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./volar": "./volar.d.ts"
  },
  "bugs": {
    "url": "https://issues.sei.cmu.edu/jira/projects/SDS"
  },
  "homepage": "https://designsystem.sei.cmu.edu/",
  "repository": {
    "type": "git",
    "url": "https://code.sei.cmu.edu/bitbucket/projects/SDS/repos/components-vue3/"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.6.3",
    "@sds/tailwindcss-3": "^3.0.0-next.82",
    "@shimyshack/uid": "^0.1.9",
    "@storybook/addon-actions": "^7.0.2",
    "@storybook/addon-docs": "^7.0.2",
    "@storybook/addon-essentials": "^7.6.17",
    "@storybook/addon-links": "^7.6.17",
    "@storybook/addon-storysource": "^7.6.17",
    "@storybook/vue3": "^7.0.2",
    "@storybook/vue3-vite": "^7.6.17",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@unhead/vue": "^1.8.10",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.4.4",
    "@vueuse/core": "^10.9.0",
    "autoprefixer": "^10.4.17",
    "date-fns": "^3.3.1",
    "esbuild": "^0.20.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "jsdom": "^24.0.0",
    "mitt": "^3.0.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^7.6.17",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-vue-router": "^0.8.4",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "vue": "^3.0.0",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.3.0",
    "vue-tsc": "^1.8.27"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
