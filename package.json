{
  "name": "@sds/components-vue3",
  "version": "2.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore . --ignore-path .eslintignore .",
    "test": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest run -c vite-library.config.js",
    "test:watch": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest -c vite-library.config.js",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/types/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/types/components/index.d.ts"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "bugs": {
    "url": "https://issues.sei.cmu.edu/jira/projects/SDS"
  },
  "homepage": "https://designsystem.sei.cmu.edu/",
  "publishConfig": {
    "cache": "~/.npm",
    "registry": "https://artifactory.sei.cmu.edu/artifactory/api/npm/sei-design-system/"
  },
  "repository": {
    "type": "git",
    "url": "https://code.sei.cmu.edu/bitbucket/projects/SDS/repos/components-vue3/"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@floating-ui/dom": "^0.5.1",
    "@rollup/plugin-eslint": "^8.0.2",
    "@sds/tailwindcss-3": "^1.0.6",
    "@shimyshack/uid": "^0.1.6",
    "@storybook/addon-actions": "^6.3.12",
    "@storybook/addon-docs": "^6.3.12",
    "@storybook/addon-essentials": "^6.5.4",
    "@storybook/addon-links": "^6.5.4",
    "@storybook/addon-storysource": "^6.5.4",
    "@storybook/vue3": "^6.5.4",
    "@tailwindcss/aspect-ratio": "^0.4.0",
    "@tailwindcss/forms": "^0.5.2",
    "@tailwindcss/line-clamp": "^0.4.0",
    "@tailwindcss/typography": "^0.5.2",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
    "@typescript-eslint/parser": "^5.25.0",
    "@vitejs/plugin-vue": "^2.3.3",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.0.0",
    "@vueuse/core": "^8.5.0",
    "autoprefixer": "^10.4.7",
    "date-fns": "^2.28.0",
    "eslint": "^8.16.0",
    "eslint-plugin-vue": "^8.7.1",
    "jsdom": "^19.0.0",
    "mitt": "^3.0.0",
    "postcss": "^8.4.14",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "storybook-builder-vite": "^0.1.23",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.4",
    "vite": "^2.9.9",
    "vitest": "^0.12.9",
    "vue": "^3.0.0",
    "vue-loader": "^17.0.0",
    "vue-tsc": "^0.34.16"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
