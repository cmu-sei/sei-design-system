{
  "name": "@cmu-sei/sei-design-system",
  "version": "3.11.1-beta.7",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "serve": "vite preview",
    "lint": "NODE_OPTIONS='--trace-warnings' eslint .",
    "test": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest run -c vite-library.config.js",
    "test:watch": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest -c vite-library.config.js",
    "test:clean": "vitest run -u",
    "coverage": "vitest run --coverage",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "release-beta": "echo 'prerelease' | ./scripts/release-beta.sh",
    "release-next": "echo 'prerelease' | ./scripts/release-next.sh",
    "create-component": "./scripts/create-component.sh",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "gen-volar-dts": "./scripts/gen-component-declarations.sh"
  },
  "files": [
    "storybook-static",
    "tailwindcss",
    "open-sans",
    "dist",
    "src",
    "volar.d.ts"
  ],
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/src/components/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js"
    },
    "./tailwindcss/*": "./tailwindcss/*",
    "./open-sans/*": "./open-sans/*",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./volar": "./volar.d.ts"
  },
  "types": "./dist/types/src/components/index.d.ts",
  "main": "./dist/index.umd.js",
  "peerDependencies": {
    "vue": ">=3.0.0",
    "tailwindcss": ">=4.0.0",
    "@tailwindcss/postcss": ">=4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.6",
    "@eslint/js": "^9.16.0",
    "@floating-ui/dom": "^1.6.13",
    "@shimyshack/uid": "^0.1.9",
    "@storybook/addon-actions": "^8.4.7",
    "@storybook/addon-docs": "^8.4.7",
    "@storybook/addon-essentials": "^8.5.3",
    "@storybook/addon-links": "^8.5.3",
    "@storybook/addon-storysource": "^8.5.3",
    "@storybook/vue3": "^8.4.7",
    "@storybook/vue3-vite": "^8.5.3",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.0.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/beautify": "^0.0.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@unhead/vue": "^1.11.19",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^12.6.1",
    "beautify": "^0.0.8",
    "date-fns": "^4.1.0",
    "esbuild": "^0.25.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "mitt": "^3.0.1",
    "postcss": "^8.5.2",
    "storybook": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "unplugin-vue-router": "^0.11.2",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.13",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
