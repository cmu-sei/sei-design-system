{
  "name": "@sds/components-vue3",
  "version": "3.2.1-beta.7",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore . --ignore-path .eslintignore .",
    "test": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest run -c vite-library.config.js",
    "test:watch": "LIB_NAME=SeiDesignSystem LIB_ROOT=src/components vitest -c vite-library.config.js",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "release-beta": "echo 'prerelease' | ./scripts/release-beta.sh",
    "release-next": "echo 'prerelease' | ./scripts/release-next.sh",
    "create-component": "./scripts/create-component.sh",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "gen-volar-dts": "./scripts/gen-component-declarations.sh"
  },
  "files": [
    "storybook-static",
    "dist",
    "src",
    "volar.d.ts"
  ],
  "sideEffects": false,
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "type": "module",
  "types": "./dist/types/src/components/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/components/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*",
    "./volar": "./volar.d.ts"
  },
  "bugs": {
    "url": "https://issues.sei.cmu.edu/jira/projects/SDS"
  },
  "homepage": "https://designsystem.sei.cmu.edu/",
  "repository": {
    "type": "git",
    "url": "https://code.sei.cmu.edu/bitbucket/projects/SDS/repos/components-vue3/"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.6.5",
    "@sds/components-vue3": "^3.2.0",
    "@sds/tailwindcss-3": "^3.0.2",
    "@shimyshack/uid": "^0.1.9",
    "@storybook/addon-actions": "^8.0.0",
    "@storybook/addon-docs": "^8.0.0",
    "@storybook/addon-essentials": "^8.1.2",
    "@storybook/addon-links": "^8.1.2",
    "@storybook/addon-storysource": "^8.1.2",
    "@storybook/vue3": "^8.0.0",
    "@storybook/vue3-vite": "^8.1.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@unhead/vue": "^1.9.10",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^10.9.0",
    "autoprefixer": "^10.4.19",
    "date-fns": "^3.6.0",
    "esbuild": "^0.21.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "jsdom": "^24.0.0",
    "mitt": "^3.0.1",
    "postcss": "^8.4.38",
    "storybook": "^8.1.2",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^0.27.0",
    "unplugin-vue-router": "^0.8.7",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "vue": "^3.0.0",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.3.2",
    "vue-tsc": "^2.0.19"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
