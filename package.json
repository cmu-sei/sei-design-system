{
  "name": "@sds/components-vue3",
  "version": "1.3.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore . --ignore-path .eslintignore .",
    "test": "jest src",
    "bundle:release": "./scripts/bundle-release.sh",
    "release": "./scripts/release.sh",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/types/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/types/components/index.d.ts"
    },
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "bugs": {
    "url": "https://issues.sei.cmu.edu/jira/projects/SDS"
  },
  "homepage": "https://designsystem.sei.cmu.edu/",
  "publishConfig": {
    "cache": "~/.npm",
    "registry": "https://artifactory.sei.cmu.edu/artifactory/api/npm/sei-design-system/"
  },
  "repository": {
    "type": "git",
    "url": "https://code.sei.cmu.edu/bitbucket/projects/SDS/repos/components-vue3/"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.15.8",
    "@babel/preset-env": "^7.15.8",
    "@popperjs/core": "^2.10.2",
    "@rollup/plugin-eslint": "^8.0.1",
    "@sds/tailwindcss-3": "^1.0.0",
    "@shimyshack/uid": "^0.1.6",
    "@storybook/addon-actions": "^6.3.12",
    "@storybook/addon-docs": "^6.3.12",
    "@storybook/addon-essentials": "^6.3.12",
    "@storybook/addon-links": "^6.3.12",
    "@storybook/addon-storysource": "^6.3.12",
    "@storybook/vue3": "^6.3.12",
    "@tailwindcss/aspect-ratio": "^0.4.0",
    "@tailwindcss/forms": "^0.4.0",
    "@tailwindcss/line-clamp": "^0.3.0",
    "@tailwindcss/typography": "^0.5.0",
    "@types/jest": "^27.0.3",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vitejs/plugin-vue": "^2.0.1",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.0.0-rc.17",
    "@vueuse/core": "^7.6.0",
    "autoprefixer": "^10.3.1",
    "babel-jest": "^26.6.3",
    "babel-loader": "^8.2.2",
    "date-fns": "^2.26.0",
    "eslint": "^8.3.0",
    "eslint-plugin-vue": "^8.2.0",
    "jest": "^26.6.3",
    "jest-transform-stub": "^2.0.0",
    "mitt": "^3.0.0",
    "postcss": "^8.3.6",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "storybook-builder-vite": "^0.1.1",
    "tailwindcss": "^3.0.0",
    "ts-jest": "^26.5.6",
    "typescript": "^4.3.2",
    "vite": "^2.7.10",
    "vue": "^3.0.0",
    "vue-jest": "^5.0.0-alpha.10",
    "vue-loader": "^16.8.1",
    "vue-tsc": "^0.30.2"
  },
  "engines": {
    "node": ">=12.13.0"
  }
}
